# Copy to .env (same folder). Never commit .env.

# Supabase — same project as MY PENS / cross_app schema (service role: server only)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Macro regime label written with daily cross-app snapshot (override if no UI yet)
INVESTING_MACRO_REGIME=neutral

# Optional: secure the daily snapshot cron route
CRON_SECRET=

NEWS_API_KEY=

# CORS — comma-separated origins. Lock down in production.
ALLOWED_ORIGINS=https://your-frontend.netlify.app

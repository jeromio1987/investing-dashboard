{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeDevCommand":   "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath":            "http://localhost:5173",
    "distDir":            "../dist"
  },
  "package": {
    "productName": "Investing Dashboard",
    "version":     "2.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": { "all": false, "open": true },
      "fs": {
        "all":          true,
        "scope":        ["$APPDATA/*", "$DOCUMENT/*"],
        "readFile":     true,
        "writeFile":    true,
        "exists":       true
      }
    },
    "bundle": {
      "active":      true,
      "targets":     "all",
      "identifier":  "com.yourdomain.investing-dashboard",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title":            "Investing Dashboard 2026",
        "width":            1440,
        "height":           900,
        "minWidth":         900,
        "minHeight":        600,
        "resizable":        true,
        "fullscreen":       false,
        "decorations":      true,
        "center":           true,
        "transparent":      false,
        "alwaysOnTop":      false
      }
    ]
  }
}
